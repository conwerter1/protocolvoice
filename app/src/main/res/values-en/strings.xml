    <!-- About / Acknowledgments screen -->
    <string name="about_title">About</string>
    <string name="about_app_name">ProtocolVoice</string>
    <string name="about_tagline">Offline interview transcription</string>
    <string name="about_version_label">Version</string>
    <string name="about_description">Offline voice recorder with on-device speech recognition and speaker diarization for audit interviews. All processing happens on the device — data never leaves your phone.</string>
    <string name="about_section_acknowledgments">Technologies used</string>
    <string name="about_ack_intro">This app uses the following open-source ML models and libraries. All code and models are distributed under the licenses of their original authors.</string>
    <string name="about_ack_gigaam_title">GigaAM — speech recognition</string>
    <string name="about_ack_gigaam_desc">Russian acoustic model by SaluteDevices (Sber AI). MIT license.</string>
    <string name="about_ack_gigaam_url">github.com/salute-developers/GigaAM</string>
    <string name="about_ack_speaker_title">3D-Speaker — speaker diarization</string>
    <string name="about_ack_speaker_desc">CAM++ and ERes2Net models by ModelScope (Alibaba). Apache 2.0 license.</string>
    <string name="about_ack_speaker_url">github.com/modelscope/3D-Speaker</string>
    <string name="about_ack_sherpa_title">sherpa-onnx</string>
    <string name="about_ack_sherpa_desc">On-device inference runtime by k2-fsa. Apache 2.0 license.</string>
    <string name="about_ack_sherpa_url">github.com/k2-fsa/sherpa-onnx</string>
    <string name="about_ack_huggingface_title">Hugging Face</string>
    <string name="about_ack_huggingface_desc">Hosting for the ML models used by this app.</string>
    <string name="about_ack_huggingface_url">huggingface.co/protocolvoice/asr-models</string>
    <string name="about_section_license">License</string>
    <string name="about_license_text">This app is distributed under the Apache 2.0 license. Source code is available on GitHub.</string>
