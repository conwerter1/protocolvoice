    <!-- About / Acknowledgments screen -->
    <string name="about_title">О программе</string>
    <string name="about_app_name">ProtocolVoice</string>
    <string name="about_tagline">Автономная расшифровка интервью</string>
    <string name="about_version_label">Версия</string>
    <string name="about_description">Оффлайновый диктофон с распознаванием речи и разделением говорящих для аудиторских интервью. Вся обработка происходит на устройстве — данные никуда не отправляются.</string>
    <string name="about_section_acknowledgments">Используемые технологии</string>
    <string name="about_ack_intro">Приложение использует следующие открытые ML-модели и библиотеки. Весь код и модели распространяются в соответствии с лицензиями оригинальных авторов.</string>
    <string name="about_ack_gigaam_title">GigaAM — распознавание речи</string>
    <string name="about_ack_gigaam_desc">Русская акустическая модель от SaluteDevices (Sber AI). Лицензия MIT.</string>
    <string name="about_ack_gigaam_url">github.com/salute-developers/GigaAM</string>
    <string name="about_ack_speaker_title">3D-Speaker — разделение говорящих</string>
    <string name="about_ack_speaker_desc">Модели CAM++ и ERes2Net от ModelScope (Alibaba). Лицензия Apache 2.0.</string>
    <string name="about_ack_speaker_url">github.com/modelscope/3D-Speaker</string>
    <string name="about_ack_sherpa_title">sherpa-onnx</string>
    <string name="about_ack_sherpa_desc">Он-девайс inference рунтайм от k2-fsa. Лицензия Apache 2.0.</string>
    <string name="about_ack_sherpa_url">github.com/k2-fsa/sherpa-onnx</string>
    <string name="about_ack_huggingface_title">Hugging Face</string>
    <string name="about_ack_huggingface_desc">Хостинг ML-моделей, использованных в приложении.</string>
    <string name="about_ack_huggingface_url">huggingface.co/protocolvoice/asr-models</string>
    <string name="about_section_license">Лицензия</string>
    <string name="about_license_text">Приложение распространяется под лицензией Apache 2.0. Исходный код доступен на GitHub.</string>
